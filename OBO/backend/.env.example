APP_NAME=WSO2 OBO Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_ORIGINS=http://localhost:8091
DEBUG_SHOW_FULL_TOKENS=false

WSO2_ISSUER=https://<is-host>:9443/<issuer-or-token-issuer>
WSO2_AUTHORIZE_ENDPOINT=https://<is-host>:9443/oauth2/authorize
WSO2_TOKEN_ENDPOINT=https://<is-host>:9443/oauth2/token
WSO2_INTROSPECTION_ENDPOINT=https://<is-host>:9443/oauth2/introspect
WSO2_JWKS_ENDPOINT=https://<is-host>:9443/oauth2/jwks

# Logical agent identity registered in WSO2. Required.
AGENT_ID=hotel-booking-agent
AGENT_CLIENT_ID=<agent-client-id>
AGENT_CLIENT_SECRET=<agent-client-secret>
AGENT_SCOPE=openid profile files.read files.write files.share
INTROSPECTION_CLIENT_ID=<introspection-client-id>
INTROSPECTION_CLIENT_SECRET=<introspection-client-secret>

# Can be the same technical OAuth client as AGENT_CLIENT_ID, but the lab no longer assumes that.
OBO_CLIENT_ID=<obo-client-id>
OBO_CLIENT_SECRET=<obo-client-secret>
OBO_REDIRECT_URI=http://localhost:8000/api/obo/callback
OBO_SCOPE=openid profile email files.read files.write files.share
OBO_AUTHORIZATION_PROMPT=consent
OBO_GRANT_TYPE=urn:ietf:params:oauth:grant-type:token-exchange
OBO_AGENT_TOKEN_PARAMETER=actor_token
OBO_AGENT_TOKEN_TYPE_PARAMETER=actor_token_type
OBO_AGENT_TOKEN_TYPE_VALUE=urn:ietf:params:oauth:token-type:access_token
OBO_SUBJECT_TOKEN_PARAMETER=subject_token
OBO_SUBJECT_TOKEN_TYPE_PARAMETER=subject_token_type
OBO_SUBJECT_TOKEN_TYPE_VALUE=urn:ietf:params:oauth:token-type:authorization_code
OBO_EXTRA_TOKEN_PARAMS_JSON={}
OBO_REQUIRE_ACT_CLAIM=true

RESOURCE_API_BASE_URL=http://localhost:8001
RESOURCE_API_TIMEOUT_SECONDS=15
