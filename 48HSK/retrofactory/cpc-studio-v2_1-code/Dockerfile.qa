FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Shared module (qa_agent reuses developer_agent's LLM builder and parser)
COPY scene_agent scene_agent

# Entry point is the QA agent server
COPY agents/qa/main.py main.py

RUN useradd -m -u 1000 appuser && chown -R appuser:appuser /app
USER appuser

EXPOSE 8000

CMD ["python", "main.py"]
