FROM python:3.12-slim

WORKDIR /app

# Only needs fastapi/uvicorn and pydantic — no LLM libraries used at runtime.
# Installing from the shared requirements.txt keeps dependency versions consistent.
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY scene_agent scene_agent
COPY agents/audio/main.py main.py

EXPOSE 8000

CMD ["python", "main.py"]
