<sequence xmlns="http://ws.apache.org/ns/synapse" name="InputSanitizationPolicy">
    <property name="invisibleUnicodeRegex"
              scope="default"
              type="STRING"
              value="[\u200B\u200C\u200D\u200E\u200F\u202A-\u202E\u2060-\u2064\uFEFF]"/>

    <property name="dangerousOperatorsRegex"
              scope="default"
              type="STRING"
              value="&amp;&amp;|\|\||==|!=|&gt;=|&lt;=|&lt;&lt;|&gt;&gt;|;(?!\s*$)|\u0060[^\u0060]*\u0060|\$\([^)]*\)"/>

    <property name="mode"
              scope="default"
              type="STRING"
              value="sanitize"/>

    <class name="com.example.apim.guardrails.InputSanitizationMediator"/>
</sequence>